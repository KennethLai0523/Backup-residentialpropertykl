rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Public property listings
    match /listings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // New launch projects (individual developments)
    match /projects/{docId} {
      allow read: if resource.data.status == "published" || isSignedIn();
      allow write: if isSignedIn();
    }

    // Developer profiles shown on /projects.html and nav dropdown
    match /developers/{docId} {
      allow read: if resource.data.status == "published" || isSignedIn();
      allow write: if isSignedIn();
    }

    // Blog posts
    match /blogs/{docId} {
      allow read: if resource.data.status == "published" || isSignedIn();
      allow write: if isSignedIn();
    }

    // Admin-only
    match /reminders/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}
