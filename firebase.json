{
  "hosting": {
    "public": ".",
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=86400"
          }
        ]
      }
    ],
    "rewrites": [


      {
        "source": "/api/importListing",
        "function": "importListing"
      },
      {
        "source": "/areas/**",
        "destination": "/area-guide.html"
      },
      {
        "source": "/rent/**",
        "destination": "/listing-cluster.html"
      },
      {
        "source": "/sale/**",
        "destination": "/listing-cluster.html"
      },
      {
        "source": "/condo/**",
        "destination": "/listing-cluster.html"
      },
      {
        "source": "/office/**",
        "destination": "/listing-cluster.html"
      },
      {
        "source": "/warehouse/**",
        "destination": "/listing-cluster.html"
      },
      {
        "source": "/categories/**",
        "destination": "/listings.html"
      },
      {
        "source": "/project/**",
        "destination": "/project-detail.html"
      },

      {
        "source": "/blog/**",
        "destination": "/blog-detail.html"
      },
      {
        "source": "/*-for-**",
        "destination": "/listings.html"
      },
      {
        "source": "/listing/**",
        "destination": "/detail.html"
      },
      {
        "source": "/sitemap.xml",
        "function": "sitemap"
      }
    ]
  },
  "functions": [
    {
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ],
      "source": "functions"
    },
    {
      "source": "blog",
      "codebase": "blog",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "asia-southeast1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
